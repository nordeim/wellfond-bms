# CHA YUAN - Production Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# =============================================================================
# Required: Core Django Settings
# =============================================================================

# Django secret key (generate with: openssl rand -base64 50)
SECRET_KEY=your-secret-key-here-minimum-50-characters-long

# Comma-separated list of production domains
ALLOWED_HOSTS=cha-yuan.sg,www.cha-yuan.sg,api.cha-yuan.sg

# =============================================================================
# Required: Database (PostgreSQL)
# =============================================================================

POSTGRES_DB=wellbond_db
POSTGRES_USER=wellbond_user
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_HOST=your-db-host.amazonaws.com
POSTGRES_PORT=5432

# Alternative: Full database URL
# DATABASE_URL=postgres://user:password@host:5432/dbname

# =============================================================================
# Required: Redis Cache
# =============================================================================

REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0

# Alternative: Separate Redis settings
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# =============================================================================
# Required: Stripe (Singapore)
# =============================================================================

# Live keys (starts with sk_live_ and pk_live_)
STRIPE_SECRET_KEY_SG=sk_live_xxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY_SG=pk_live_xxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET_SG=whsec_xxxxxxxxxxxxxx

# =============================================================================
# Optional: Security Headers
# =============================================================================

# Force HTTPS redirects (default: True)
SECURE_SSL_REDIRECT=True

# HSTS max-age in seconds (default: 31536000 = 1 year)
SECURE_HSTS_SECONDS=31536000

# =============================================================================
# Optional: Email (SMTP)
# =============================================================================

EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=orders@cha-yuan.sg
SERVER_EMAIL=errors@cha-yuan.sg

# =============================================================================
# Optional: Error Tracking
# =============================================================================

SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# =============================================================================
# Optional: Admin Settings
# =============================================================================

# Custom admin URL path (for obscurity)
ADMIN_URL=staff-admin/

# Disable startup health checks (default: True)
RUN_STARTUP_CHECKS=True

# =============================================================================
# Singapore Market Settings
# =============================================================================

# These are hardcoded in settings but can be overridden
# GST_RATE=0.09
# TIME_ZONE=Asia/Singapore
# LANGUAGE_CODE=en-sg

# =============================================================================
# Security Notes
# =============================================================================

# 1. NEVER use DEBUG=True in production
# 2. NEVER use test Stripe keys in production
# 3. NEVER commit this file with real values
# 4. Rotate secrets regularly (quarterly recommended)
# 5. Use strong passwords (use a password manager)
# 6. Enable 2FA on all service accounts (Stripe, SendGrid, etc.)
