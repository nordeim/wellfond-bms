# =============================================================================
# Wellfond BMS - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!
# =============================================================================

# =============================================================================
# Database Configuration (PostgreSQL 17)
# =============================================================================
# Development: Connects to containerized PostgreSQL on localhost:5432
# Production: Connects via PgBouncer connection pooler

DB_PASSWORD=wellfond_dev_password
DATABASE_URL=postgresql://wellfond_user:wellfond_dev_password@127.0.0.1:5432/wellfond_db
DB_NAME=wellfond_db
DB_USER=wellfond_user
DB_HOST=127.0.0.1
DB_PORT=5432

# =============================================================================
# Test Database
# =============================================================================
TEST_DB_NAME=wellfond_test_db

# =============================================================================
# Redis Configuration (Redis 7.4)
# =============================================================================
# Development: Single Redis instance on localhost:6379
# Production: 3 separate instances (sessions, broker, cache)

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_SESSIONS_URL=redis://127.0.0.1:6379/1
REDIS_BROKER_URL=redis://127.0.0.1:6379/2
REDIS_CACHE_URL=redis://127.0.0.1:6379/0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# Django Settings
# =============================================================================

# SECURITY WARNING: Keep the secret key used in production secret!
# Generate with: openssl rand -base64 50
SECRET_KEY=dev-secret-key-change-in-production-2026-wellfond-singapore

# Development: True | Production: False
DEBUG=True

# Django settings module
DJANGO_SETTINGS_MODULE=config.settings.development

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.1,backend,wellfond-backend

# =============================================================================
# Frontend BFF Configuration
# =============================================================================

# Development: Native Django on localhost:8000
# Production: Internal Docker network http://django:8000
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# =============================================================================
# CORS & CSRF Configuration
# =============================================================================

CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Stripe Configuration (Singapore)
# =============================================================================

# Test Keys (Development)
STRIPE_PUBLISHABLE_KEY=pk_test_singapore_placeholder
STRIPE_SECRET_KEY=sk_test_singapore_placeholder
STRIPE_WEBHOOK_SECRET=whsec_singapore_placeholder

# =============================================================================
# Gotenberg (PDF Generation) - Optional for Development
# =============================================================================

# Development: Optional or use mock
GOTENBERG_URL=http://localhost:3001

# =============================================================================
# OpenTelemetry / Observability
# =============================================================================

# Development: Disabled
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=wellfond-bms
SENTRY_DSN=

# =============================================================================
# Email Configuration (Optional)
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@wellfond.sg

# =============================================================================
# Singapore Market Context
# =============================================================================

CURRENCY=SGD
GST_RATE=0.09
TIMEZONE=Asia/Singapore
LOCALE=en_SG

# =============================================================================
# Security Settings (Production Only)
# =============================================================================

# Force HTTPS redirects (Production: True, Development: False)
SECURE_SSL_REDIRECT=False

# HSTS max-age in seconds (1 year = 31536000)
SECURE_HSTS_SECONDS=0

# =============================================================================
# Celery Settings
# =============================================================================

CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# =============================================================================
# File Upload Settings
# =============================================================================

# Max upload size in MB
MAX_UPLOAD_SIZE=10

# =============================================================================
# AI Sandbox Settings
# =============================================================================

# OpenAI / Anthropic API Keys (if using AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# Notes
# =============================================================================

# 1. NEVER commit .env file with real values
# 2. Rotate secrets regularly (quarterly recommended)
# 3. Use strong passwords (use a password manager)
# 4. Enable 2FA on all service accounts (Stripe, SendGrid, etc.)
# 5. Development uses hybrid: containerized PG/Redis + native Django/Next.js
# 6. Production uses full containerization with PgBouncer and Gotenberg
