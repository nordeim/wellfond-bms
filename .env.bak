# WELLFOND Environment Configuration
# Development Environment - Singapore Market

# =============================================================================
# Database Configuration (PostgreSQL 17)
# =============================================================================
DB_PASSWORD=wellfond_dev_password
DATABASE_URL=postgresql://wellfond_user:wellfond_dev_password@localhost:5432/wellfond_db
DB_NAME=wellfond_db
DB_USER=wellfond_user
DB_HOST=localhost
DB_PORT=5432

# Test Database
TEST_DB_NAME=wellfond_test_db

# =============================================================================
# Django Settings
# =============================================================================
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production-2026-wellfond-singapore
DJANGO_SETTINGS_MODULE=config.settings.development

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend,wellfond-backend

# =============================================================================
# Redis Configuration (Redis 7.4)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Redis Split Instances (for sessions, broker, cache, idempotency)
REDIS_CACHE_URL=redis://localhost:6379/0
REDIS_SESSIONS_URL=redis://localhost:6379/1
REDIS_BROKER_URL=redis://localhost:6379/2
REDIS_IDEMPOTENCY_URL=redis://localhost:6379/3

# =============================================================================
# Stripe Configuration (Singapore)
# =============================================================================
STRIPE_PUBLISHABLE_KEY=pk_test_singapore_placeholder
STRIPE_SECRET_KEY=sk_test_singapore_placeholder
STRIPE_WEBHOOK_SECRET=whsec_singapore_placeholder

# =============================================================================
# Singapore Market Context
# =============================================================================
CURRENCY=SGD
GST_RATE=0.09
TIMEZONE=Asia/Singapore
LOCALE=en_SG

# =============================================================================
# Security (Development Only)
# =============================================================================
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
